{
  "name": "mockcraft",
  "version": "0.1.0",
  "description": "The smartest local mock server — AI-powered fixtures, proxy recording, and a beautiful inspector UI.",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "mockcraft": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "ui-dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:ui": "cd ui && npm run build",
    "build:all": "npm run build && npm run build:ui",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:all",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "mock",
    "mock-server",
    "api",
    "fixtures",
    "proxy",
    "ai",
    "ollama",
    "openapi",
    "developer-tools",
    "testing"
  ],
  "author": "Favaz Musthafa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/favazmusthafa/Mockcraft"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "commander": "^12.1.0",
    "hono": "^4.6.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^15.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.1.0"
  }
}